# OpenRouter API (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-actual-key-here

# RAGAS Judge Model (free NVIDIA model)
JUDGE_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Local Ollama model for answer generation
ANSWER_MODEL=gemma4:e4b

# Optional paths
CHROMA_DB_PATH=./chroma_db
TEST_DATA_PATH=test_data.json